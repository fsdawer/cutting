# ================================================================
# BeautyBook 환경변수
# ----------------------------------------------------------------
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워주세요.
# .env 는 .gitignore 에 등록되어 있어서 Git에 올라가지 않습니다.
# ================================================================

# ── MySQL ───────────────────────────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=여기에_MySQL_비밀번호

# ── JWT ─────────────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열 (영문+숫자 혼합 권장)
JWT_SECRET=여기에_랜덤_시크릿키_최소32자이상

# ── 네이버 SMTP (이메일 발송) ────────────────────────────────────
# 네이버 로그인 → 환경설정 → 보안설정 → SMTP 사용 허용 후 사용
NAVER_MAIL_USERNAME=네이버아이디@naver.com
NAVER_MAIL_PASSWORD=네이버_비밀번호

# ── 카카오 OAuth2 ────────────────────────────────────────────────
# https://developers.kakao.com → 내 앱 → 앱 키 → REST API 키
KAKAO_CLIENT_ID=카카오_REST_API_KEY
# 카카오 → 내 앱 → 보안 → Client Secret
KAKAO_CLIENT_SECRET=카카오_CLIENT_SECRET

# ── 네이버 OAuth2 ────────────────────────────────────────────────
# https://developers.naver.com → Application → 등록한 앱 → Client ID
NAVER_CLIENT_ID=네이버_CLIENT_ID
NAVER_CLIENT_SECRET=네이버_CLIENT_SECRET
